# OpenClaw Nexus environment example
#
# Default profile: local development. Values that are unsafe for internal
# production are marked as explicit development opt-ins instead of silently
# looking production-ready. Copy this file to config/.env and replace all
# placeholder secrets through your secret-management mechanism.

# Deployment profile: development | internal-production
NEXUSCTL_DEPLOYMENT_MODE=development

# Nexusctl API - local development default is loopback-safe.
NEXUSCTL_API_HOST=127.0.0.1
NEXUSCTL_API_PORT=8080
NEXUSCTL_API_TIMEOUT_SECONDS=5
NEXUSCTL_API_READ_RETRIES=1
NEXUSCTL_API_MAX_BODY_BYTES=1048576

# Internal production: expose the API only behind a reverse proxy/TLS boundary.
# Keep these insecure opt-ins at 0 outside disposable local/dev networks.
NEXUSCTL_API_TLS_ENABLED=0
NEXUSCTL_API_ALLOW_INSECURE_REMOTE_BIND=0
NEXUSCTL_API_ALLOW_INSECURE_REMOTE=0

# Persistent runtime paths. In Docker these map to named volumes.
NEXUSCTL_DB=/data/nexus.db
NEXUSCTL_BACKUP_DIR=/backups
NEXUSCTL_RECOVERY_EVIDENCE_DIR=/recovery-evidence
NEXUSCTL_BACKUP_RETENTION_DAYS=30
NEXUSCTL_BACKUP_RETENTION_MIN_COPIES=7
NEXUSCTL_OFFSITE_BACKUP_ENABLED=0
NEXUSCTL_OFFSITE_BACKUP_TARGET=operator-managed-offsite-location
NEXUSCTL_OFFSITE_BACKUP_SCHEDULE=daily
NEXUSCTL_PROJECT_ROOT=/workspace
NEXUSCTL_WORKSPACES_DIR=/workspaces
NEXUSCTL_REPO_WORKTREES_DIR=/repo-worktrees
NEXUSCTL_WORKER_INTERVAL_SECONDS=300
NEXUSCTL_TOKEN=

# OpenClaw gateway wrapper
OPENCLAW_GATEWAY_PORT=8090
OPENCLAW_BASE_IMAGE=python:3.11-slim

# GitHub App projection credentials. Mock mode may leave these empty.
# Internal production with webhook reconciliation requires a real secret.
NEXUSCTL_GITHUB_MODE=mock
NEXUSCTL_WEBHOOK_RECONCILIATION_ENABLED=0
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app_private_key.pem
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

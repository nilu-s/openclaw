{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "127.0.0.1",
    "trustedProxies": [],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "allowTailscale": false
    },
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw",
      "allowedOrigins": [
        "capacitor://localhost",
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ],
      "allowInsecureAuth": false,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "tools": {
    "profile": "read-only"
  },
  "skills": {
    "load": {
      "watch": true,
      "watchDebounceMs": 250,
      "extraDirs": [
        "/workspace/skills"
      ]
    }
  },
  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [
        60000,
        120000,
        300000
      ],
      "retryOn": [
        "rate_limit",
        "overloaded",
        "network",
        "server_error"
      ]
    },
    "sessionRetention": "48h",
    "runLog": {
      "maxBytes": "5mb",
      "keepLines": 3000
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "tools": {
        "profile": "read-only"
      },
      "models": {
        "openai-codex/gpt-5.5": {},
        "openai-codex/gpt-5.4": {},
        "ollama/kimi-k2.6:cloud": {}
      },
      "model": {
        "primary": "openai-codex/gpt-5.5",
        "fallbacks": [
          "ollama/kimi-k2.6:cloud",
          "openai-codex/gpt-5.4"
        ]
      },
      "heartbeat": {
        "every": "10m"
      },
      "memorySearch": {
        "enabled": true,
        "sources": [
          "memory",
          "sessions"
        ]
      },
      "skills": [
        "nexusctl_lifecycle",
        "nexusctl_output_discipline"
      ]
    },

# Copy this file to .env for local/private deployments. Never commit real secrets.
# Supply a versioned image pinned by digest, for example:
# OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:vX.Y.Z@sha256:<digest>
OPENCLAW_BASE_IMAGE=
NEXUS_OPENCLAW_IMAGE=nexus-openclaw:local

OPENCLAW_CONTAINER_NAME=openclaw-gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=127.0.0.1
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

OPENCLAW_OLLAMA_API_KEY=ollama-local
OPENCLAW_OLLAMA_BASE_URL=http://host.docker.internal:11434

OPENCLAW_CRON_PROVIDER_PLUGIN_IDS=ollama
OPENCLAW_CRON_SKIP_PROVIDER_CATALOG_AUGMENT=1

OPENCLAW_REMOTE_SSH_TARGET=
OPENCLAW_REMOTE_SSH_WORKSPACE_ROOT=/opt/openclaw/workspace
OPENCLAW_REMOTE_SSH_IDENTITY_FILE=/home/node/.ssh/id_ed25519
OPENCLAW_REMOTE_SSH_KNOWN_HOSTS_FILE=/home/node/.ssh/known_hosts

NEXUS_GITHUB_TOKEN=
NEXUS_GITHUB_WEBHOOK_SECRET=

NEXUSCTL_API_BASE_URL=http://127.0.0.1:8080
NEXUSCTL_ALLOW_INSECURE_REMOTE=false
